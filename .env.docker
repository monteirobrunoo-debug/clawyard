# ClawYard — dev local Docker (.env.docker)
# Copiado para .env pelo entrypoint. NÃO contém segredos de produção.
# Para testar agentes Anthropic, mete a tua ANTHROPIC_API_KEY abaixo.

APP_NAME="ClawYard DEV"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Postgres (container) ────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=pgsql
DB_PORT=5432
DB_DATABASE=clawyard
DB_USERNAME=clawyard
DB_PASSWORD=clawyard_local

# ── Redis (container) ───────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# ── Octane ──────────────────────────────────────────────────────────────────
OCTANE_SERVER=swoole
OCTANE_MAX_EXECUTION_TIME=180

# ── Anthropic (mete a tua key para testar agentes; deixa vazio para skip) ───
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_OPUS=claude-opus-4-8
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001

# ── Integrações externas DESLIGADAS em dev (não tocar SAP/QNAP/email reais) ─
SAP_ENABLED=false
MAIL_MAILER=log
QNAP_MIRROR_ENABLED=false
AUTO_ANALYSIS_ENABLED=false

# ── Budget cap baixo em dev ─────────────────────────────────────────────────
USER_DAILY_BUDGET_EUR=5.0

# ── Filesystem local (não DO Spaces) ────────────────────────────────────────
FILESYSTEM_DISK=local
