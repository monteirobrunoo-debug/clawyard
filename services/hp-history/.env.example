# Copy to .env (chmod 600) and fill in.
# The deploy-do.sh script does this interactively the first time.

# Must match the clawyard side: config('services.hp_history.hmac_secret')
HPH_HMAC_SECRET=

# Embeddings — pick one provider and stick with it (the dim is baked
# into the chunks table; switching = re-ingest).
HPH_EMBEDDING_PROVIDER=voyage
HPH_EMBEDDING_MODEL=voyage-3-large
HPH_EMBEDDING_DIM=1024
HPH_VOYAGE_API_KEY=

# Or:
# HPH_EMBEDDING_PROVIDER=openai
# HPH_EMBEDDING_MODEL=text-embedding-3-small
# HPH_EMBEDDING_DIM=1536
# HPH_OPENAI_API_KEY=
