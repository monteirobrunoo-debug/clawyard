APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Production: LOG_LEVEL should be "warning" or "error" so debug noise with
# filenames, exception traces and query hints never lands on disk beyond
# what's needed for incident response. `debug` is local-only.
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# SESSION_ENCRYPT=true encrypts the session payload at rest (database table
# `sessions`) using APP_KEY. Recommended for production because sessions
# hold CSRF tokens, authenticated user id and pending_opp state.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@hp-group.org"
MAIL_FROM_NAME="HP-Group / ClawYard"
# Production: when MAIL_HOST points to a remote relay (Mailgun/SES/etc.),
# config/mail.php auto-enables STARTTLS. If you want to override (e.g. pin
# to SMTPS on port 465) uncomment the next line:
# MAIL_ENCRYPTION=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# European Patent Office OPS API
EPO_CONSUMER_KEY=
EPO_CONSUMER_SECRET=

# Tavily — powers WebSearchService (Quantum, Patent, Briefing, Acingov
# agents go to the internet through this). Get a key at https://app.tavily.com
# → API Keys. Format: tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Without this set, agents return "(Web search not available)".
TAVILY_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# LLM egress control (Anthropic)
# ──────────────────────────────────────────────────────────────────────────
# All 24+ agents POST to Anthropic via config('services.anthropic.base_uri'),
# which reads ANTHROPIC_BASE_URL. Leave blank to hit api.anthropic.com
# directly. Point it at the company Digital Ocean proxy to keep every
# outbound prompt inside your infrastructure first (logging, redaction,
# rate-limit enforcement) before it is forwarded upstream.
#
# Example (Digital Ocean droplet running the proxy):
#   ANTHROPIC_BASE_URL=https://llm-proxy.partyard.eu
#
# The proxy MUST preserve /v1/messages path + headers + SSE streaming
# behaviour. A simple nginx config is documented at doc/egress-proxy.md.
ANTHROPIC_BASE_URL=

# When true, prompts are scrubbed (emails, phones, NIF, IBAN, card numbers,
# PEM private keys, key=value secrets) via App\Support\PiiRedactor BEFORE
# they leave the server. The original text still lands (encrypted) in
# messages.content. Turn on in production unless the upstream destination
# is a fully trusted DO proxy that already handles redaction.
ANTHROPIC_REDACT_PII=false

# Optional — pin the CA bundle used to verify api.anthropic.com (defence
# against rogue CAs). Point at a PEM file with the ISRG Root X1 + Let's
# Encrypt R3 cert chain. Leave empty to trust the system CA store.
ANTHROPIC_CA_BUNDLE=

# Retention — oldest agent_share_access_logs rows deleted by
# `php artisan agentshares:cleanup` (scheduled daily). Default 90 days.
AGENT_SHARE_LOG_RETENTION_DAYS=90
